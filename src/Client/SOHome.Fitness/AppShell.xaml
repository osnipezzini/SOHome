<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SOHome.Fitness.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SOHome.Fitness.Pages"
    xmlns:routes="clr-namespace:SOHome.Fitness">

    <TabBar>
        <ShellContent
        Title="Autenticação"
        ContentTemplate="{DataTemplate local:LoginPage}"
        Route="LoginPage" />
    </TabBar>

    <ShellContent
        Title="Página inicial"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route= "MainPage" />
    <ShellContent
        Title="Exercícios"
        ContentTemplate="{DataTemplate local:ExercisesPage}"
        Route="ExercisesPage" />
    <ShellContent
        Title="Meus Exercícios"
        ContentTemplate="{DataTemplate local:MyExercisesPage}"
        Route="MyExercisesPage"/>
</Shell>
